    },
    {
      "cell_type": "code",
      "source": [
        "import zipfile, os, shutil\n",
        "\n",
        "# Step 1 - extract roboflow export\n",
        "with zipfile.ZipFile('/content/drive/MyDrive/roboflow_export/toll-plaza-vision-system.yolov8.zip', 'r') as z:\n",
        "    z.extractall('/content/roboflow_data')\n",
        "\n",
        "# Step 2 - see what folders exist\n",
        "print(os.listdir('/content/roboflow_data'))"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "ekYP8IJhpk7c",
        "outputId": "b77139f5-56cd-4f34-b811-b1b4cfacb45f"
      },
      "id": "ekYP8IJhpk7c",
      "execution_count": 10,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "['README.roboflow.txt', 'README.dataset.txt', 'data.yaml', 'train']\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# Step 2 - get labeled image filenames\n",
        "labeled = set(os.listdir('/content/roboflow_data/train/images'))\n",
        "print(f\"Already labeled: {len(labeled)} images\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "Iub_oW_9qNm-",
        "outputId": "b41718d3-3578-411b-800a-160b0c021c0d"
      },
      "id": "Iub_oW_9qNm-",
      "execution_count": 11,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Already labeled: 1593 images\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "import shutil\n",
        "\n",
        "SAMPLED = '/content/drive/MyDrive/vision_data/sampled_frames'\n",
        "CVAT_OUT = '/content/drive/MyDrive/vision_data/cvat_upload'\n",
        "os.makedirs(CVAT_OUT, exist_ok=True)\n",
        "\n",
        "copied = 0\n",
        "for folder in os.listdir(SAMPLED):\n",
        "    folder_path = os.path.join(SAMPLED, folder)\n",
        "    for img in os.listdir(folder_path):\n",
        "        if img not in labeled:\n",
        "            shutil.copy(os.path.join(folder_path, img), CVAT_OUT)\n",
        "            copied += 1\n",
        "\n",
        "print(f\"Unlabeled images copied to cvat_upload: {copied}\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "gRHhBXsYqZGk",
        "outputId": "bb439fe5-47bb-499c-9acf-e1dbebbad262"
      },
      "id": "gRHhBXsYqZGk",
      "execution_count": 12,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Unlabeled images copied to cvat_upload: 2936\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# See what filenames look like in roboflow export\n",
        "roboflow_files = list(os.listdir('/content/roboflow_data/train/images'))\n",
        "print(\"Roboflow filenames sample:\")\n",
        "print(roboflow_files[:5])\n",
        "\n",
        "# See what filenames look like in sampled_frames\n",
        "sample_folder = os.listdir(SAMPLED)[0]\n",
        "sample_files = os.listdir(os.path.join(SAMPLED, sample_folder))\n",
        "print(\"\\nSampled frames filenames sample:\")\n",
        "print(sample_files[:5])"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "UcykiklXrXCT",
        "outputId": "bfac8be0-11b9-4af2-b759-e747fae44224"
      },
      "id": "UcykiklXrXCT",
      "execution_count": 13,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Roboflow filenames sample:\n",
            "['night_cctv_01555_jpg.rf.C2gNl4xQA47F8OfXocT0.jpg', 'rain_fog_moving_06566_jpg.rf.Hn7YFAQy5vX2V7FEOe6Y.jpg', 'night_moving_00794_jpg.rf.24942DuhTYOaCB6x2W29.jpg', 'night_moving_04872_jpg.rf.StYnBpSHhjMJY5SQFp5o.jpg', 'night_moving_05156_jpg.rf.z9Gg8XxkHqh4Lae0mUbA.jpg']\n",
            "\n",
            "Sampled frames filenames sample:\n",
            "['night_moving_03702.jpg', 'night_moving_03444.jpg', 'night_moving_05239.jpg', 'night_moving_03846.jpg', 'night_moving_00337.jpg']\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# Extract original names from roboflow filenames\n",
        "# night_moving_00794_jpg.rf.HASH.jpg → night_moving_00794.jpg\n",
        "labeled_original = set()\n",
        "for f in labeled:\n",
        "    # remove the _jpg.rf.HASH part\n",
        "    original = f.split('_jpg.rf.')[0] + '.jpg'\n",
        "    labeled_original.add(original)\n",
        "\n",
        "print(f\"Labeled original names: {len(labeled_original)}\")\n",
        "print(list(labeled_original)[:5])"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "XrY9YeBgrjzU",
        "outputId": "539d812f-5d40-4eac-c7fe-3451a651063b"
      },
      "id": "XrY9YeBgrjzU",
      "execution_count": 14,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Labeled original names: 1593\n",
            "['rain_fog_moving_03958.jpg', 'day_cctv_00050.jpg', 'night_cctv_01549.jpg', 'rain_fog_moving_04581.jpg', 'rain_fog_moving_07212.jpg']\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# Clear the previous wrong cvat_upload folder\n",
        "import shutil, os\n",
        "shutil.rmtree(CVAT_OUT)\n",
        "os.makedirs(CVAT_OUT, exist_ok=True)\n",
        "\n",
        "# Copy only unlabeled images\n",
        "copied = 0\n",
        "for folder in os.listdir(SAMPLED):\n",
        "    folder_path = os.path.join(SAMPLED, folder)\n",
        "    if not os.path.isdir(folder_path):\n",
        "        continue\n",
        "    for img in os.listdir(folder_path):\n",
        "        if img not in labeled_original:\n",
        "            shutil.copy(os.path.join(folder_path, img), CVAT_OUT)\n",
        "            copied += 1\n",
        "\n",
        "print(f\"Unlabeled images copied to cvat_upload: {copied}\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "dT0vlXyFrtij",
        "outputId": "34bceb01-47c0-4cee-973a-a1a6c2eab479"
      },
      "id": "dT0vlXyFrtij",
