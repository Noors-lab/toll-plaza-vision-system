      "id": "WwH0yS9YfXEw"
    },
    {
      "cell_type": "code",
      "source": [
        "import os\n",
        "\n",
        "# ─── FINAL CLASS MAPPING ───\n",
        "# 0: car, 1: motorcycle, 2: bus, 3: truck\n",
        "# 4: microbus, 5: auto, 6: human, 7: unknown, 8: bicycle\n",
        "\n",
        "# Roboflow label IDs → final IDs\n",
        "rf_remap = {\n",
        "    0: 5,   # auto → 5\n",
        "    1: 8,   # bicycle → 8\n",
        "    2: 2,   # bus → 2\n",
        "    3: 0,   # car → 0\n",
        "    4: 6,   # human → 6\n",
        "    5: 1,   # motorcycle → 1\n",
        "    6: 3,   # truck → 3\n",
        "    7: -1,  # x → remove\n",
        "}\n",
        "\n",
        "# CVAT label IDs → final IDs\n",
        "cvat_remap = {\n",
        "    0: 0,   # car → 0\n",
        "    1: 1,   # motorcycle → 1\n",
        "    2: 2,   # bus → 2\n",
        "    3: 3,   # truck → 3\n",
        "    4: 7,   # Unknown → 7\n",
        "    5: 5,   # auto → 5\n",
        "    6: 4,   # microbus → 4\n",
        "    7: 6,   # human → 6\n",
        "    8: -1,  # bicycle → remove (no CVAT labels)\n",
        "}\n",
        "\n",
        "def remap_label_file(path, remap):\n",
        "    with open(path, 'r') as f:\n",
        "        lines = f.readlines()\n",
        "\n",
        "    new_lines = []\n",
        "    for line in lines:\n",
        "        line = line.strip()\n",
        "        if not line:\n",
        "            continue\n",
        "        parts = line.split()\n",
        "        old_id = int(parts[0])\n",
        "        new_id = remap.get(old_id, -1)\n",
        "        if new_id == -1:\n",
        "            continue  # skip removed classes\n",
        "        parts[0] = str(new_id)\n",
        "        new_lines.append(' '.join(parts))\n",
        "\n",
        "    with open(path, 'w') as f:\n",
        "        f.write('\\n'.join(new_lines))\n",
        "\n",
        "label_dir = '/content/drive/MyDrive/final_dataset/train/labels'\n",
        "rf_count = 0\n",
        "cvat_count = 0\n",
        "\n",
        "for f in os.listdir(label_dir):\n",
        "    path = os.path.join(label_dir, f)\n",
        "    if 'rf.' in f:  # Roboflow file\n",
        "        remap_label_file(path, rf_remap)\n",
        "        rf_count += 1\n",
        "    else:  # CVAT file\n",
        "        remap_label_file(path, cvat_remap)\n",
        "        cvat_count += 1\n",
        "\n",
        "print(f\"Roboflow files remapped: {rf_count}\")\n",
        "print(f\"CVAT files remapped: {cvat_count}\")\n",
        "print(\"Done!\")"
      ],
