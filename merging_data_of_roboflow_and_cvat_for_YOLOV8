      "source": [
        "import os, shutil, random\n",
        "\n",
        "# Output folders\n",
        "MERGED_IMAGES = '/content/merged/images'\n",
        "MERGED_LABELS = '/content/merged/labels'\n",
        "os.makedirs(MERGED_IMAGES, exist_ok=True)\n",
        "os.makedirs(MERGED_LABELS, exist_ok=True)\n",
        "\n",
        "# ─── 1. Copy Roboflow data ───\n",
        "rf_images = '/content/roboflow_data/train/images'\n",
        "rf_labels = '/content/roboflow_data/train/labels'\n",
        "\n",
        "rf_count = 0\n",
        "for img in os.listdir(rf_images):\n",
        "    name = os.path.splitext(img)[0]\n",
        "    img_src = os.path.join(rf_images, img)\n",
        "    lbl_src = os.path.join(rf_labels, name + '.txt')\n",
        "    if os.path.exists(lbl_src):\n",
        "        shutil.copy(img_src, os.path.join(MERGED_IMAGES, img))\n",
        "        shutil.copy(lbl_src, os.path.join(MERGED_LABELS, name + '.txt'))\n",
        "        rf_count += 1\n",
        "\n",
        "print(f\"Roboflow images merged: {rf_count}\")\n",
        "\n",
        "# ─── 2. Copy CVAT data ───\n",
        "cvat_images = '/content/cvat_data/obj_train_data/cvat_upload'\n",
        "cvat_labels = '/content/cvat_data/obj_train_data/cvat_upload'\n",
        "\n",
        "cvat_count = 0\n",
        "for f in os.listdir(cvat_images):\n",
        "    if f.endswith('.jpg') or f.endswith('.png'):\n",
        "        name = os.path.splitext(f)[0]\n",
        "        img_src = os.path.join(cvat_images, f)\n",
        "        lbl_src = os.path.join(cvat_labels, name + '.txt')\n",
        "        if os.path.exists(lbl_src):\n",
        "            shutil.copy(img_src, os.path.join(MERGED_IMAGES, f))\n",
        "            shutil.copy(lbl_src, os.path.join(MERGED_LABELS, name + '.txt'))\n",
        "            cvat_count += 1\n",
        "\n",
        "print(f\"CVAT images merged: {cvat_count}\")\n",
        "print(f\"Total merged: {rf_count + cvat_count}\")"
