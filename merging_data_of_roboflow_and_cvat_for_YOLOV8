      "source": [
        "# Create split folders\n",
        "for split in ['train', 'val', 'test']:\n",
        "    os.makedirs(f'/content/final_dataset/{split}/images', exist_ok=True)\n",
        "    os.makedirs(f'/content/final_dataset/{split}/labels', exist_ok=True)\n",
        "\n",
        "# Copy files\n",
        "def copy_split(files, split):\n",
        "    for img in files:\n",
        "        name = os.path.splitext(img)[0]\n",
        "        shutil.copy(os.path.join(MERGED_IMAGES, img), f'/content/final_dataset/{split}/images/{img}')\n",
        "        lbl = name + '.txt'\n",
        "        lbl_src = os.path.join(MERGED_LABELS, lbl)\n",
        "        if os.path.exists(lbl_src):\n",
        "            shutil.copy(lbl_src, f'/content/final_dataset/{split}/labels/{lbl}')\n",
        "\n",
        "copy_split(train_files, 'train')\n",
        "copy_split(val_files, 'val')\n",
        "copy_split(test_files, 'test')\n",
        "print(\"Split done!\")\n",
        "\n",
        "# Save to Drive immediately\n",
        "shutil.copytree('/content/final_dataset', '/content/drive/MyDrive/final_dataset')\n",
        "print(\"Saved to Drive!\")"
