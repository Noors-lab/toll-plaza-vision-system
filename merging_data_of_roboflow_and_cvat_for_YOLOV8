    {
      "cell_type": "code",
      "source": [
        "import random\n",
        "from collections import defaultdict\n",
        "\n",
        "# Group images by condition (night/rain/day) as proxy for stratification\n",
        "groups = defaultdict(list)\n",
        "for img in os.listdir(MERGED_IMAGES):\n",
        "    if 'night_moving' in img:\n",
        "        groups['night_moving'].append(img)\n",
        "    elif 'rain_fog' in img:\n",
        "        groups['rain_fog'].append(img)\n",
        "    elif 'night_cctv' in img:\n",
        "        groups['night_cctv'].append(img)\n",
        "    elif 'day_cctv' in img:\n",
        "        groups['day_cctv'].append(img)\n",
        "    else:\n",
        "        groups['other'].append(img)\n",
        "\n",
        "train_files, val_files, test_files = [], [], []\n",
        "\n",
        "for group, files in groups.items():\n",
        "    random.shuffle(files)\n",
        "    total = len(files)\n",
        "    t_end = int(total * 0.70)\n",
        "    v_end = int(total * 0.85)\n",
        "    train_files += files[:t_end]\n",
        "    val_files += files[t_end:v_end]\n",
        "    test_files += files[v_end:]\n",
        "    print(f\"{group}: train={t_end} val={v_end-t_end} test={total-v_end}\")\n",
        "\n",
        "print(f\"\\nTotal — Train: {len(train_files)} Val: {len(val_files)} Test: {len(test_files)}\")"
      ],
